# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/productivity_db?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_secure
JWT_EXPIRES_IN=7d

# CORS Allowed Origins (Comma-separated for local client dashboard and Chrome Extension id)
CORS_ORIGIN=http://localhost:5173,chrome-extension://your_extension_id
